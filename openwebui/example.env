#Fonctionnels

WEBUI_URL=https://openwebui.company
WEBUI_SECRET_KEY=<RANDOM>

# PostreSQL

PG_PASS=<RANDOM>
PG_USER=<USER>

ENABLE_OAUTH_SIGNUP=true
OAUTH_MERGE_ACCOUNTS_BY_EMAIL=true
OAUTH_PROVIDER_NAME=Authentik
OPENID_PROVIDER_URL=https://<authentik-url>/application/o/<App-name>/.well-known/openid-configuration
OAUTH_CLIENT_ID=<Client-ID>
OAUTH_CLIENT_SECRET=<Client-Secret>
OAUTH_SCOPES=openid email profile
OPENID_REDIRECT_URI=https://<open-webui>/oauth/oidc/callback
ENABLE_LOGIN_FORM=false

QDRANT_API_KEY=<RANDOM>
RAG_EMBEDDING_MODEL=text-embedding-3-small  # Alias LiteLLM utilisé par le RAG

# MCP (mcpo)

PUBMED_API_KEY=              # Optionnel — améliore le rate limit PubMed (3→10 req/s)
SEMANTIC_SCHOLAR_API_KEY=    # Optionnel — améliore les quotas Semantic Scholar
WOS_API_KEY=                 # Optionnel — requis pour Web of Science dans paper-search
WOS_API_VERSION=v1           # v1 recommandé

# Open Terminal

OPEN_TERMINAL_API_KEY=<RANDOM>
OPEN_TERMINAL_URL=http://open-terminal:8000

# LiteLLM

LITELLM_MASTER_KEY=<RANDOM>
LITELLM_SALT_KEY=<RANDOM>
#Administration LiteLLM
LITELLM_UI_USERNAME=<ADMIN>
LITELLM_UI_PASSWORD=<RANDOM>

# Clés fournisseurs (toutes optionnelles, selon usage)

OPENROUTER_API_KEY=
OPENROUTER_API_BASE=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

POLLINATIONS_API_KEY=

# Pipelines (Alyx — LangGraph multi-agent)

PIPELINES_API_KEY=<RANDOM>
CONTEXT7_API_KEY=